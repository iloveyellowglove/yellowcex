# ─── YellowCEX Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values

# ── Environment ──
NODE_ENV=development          # development | production
NETWORK=testnet               # testnet | mainnet
PORT=4000

# ── Supabase (Postgres) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ── JWT ──
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# ── Binance ──
# For mainnet use: wss://stream.binance.com:9443/ws
BINANCE_WS_URL=wss://stream.testnet.binance.vision:9443/ws
BINANCE_REST_URL=https://testnet.binance.vision

# ── Ethereum / BSC RPC (for wallet operations) ──
ETH_RPC=https://sepolia.infura.io/v3/your-infura-key
# ETH_RPC=https://mainnet.infura.io/v3/your-key  # mainnet

# ── HD Wallet ──
HD_WALLET_MNEMONIC=abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about
ENCRYPTION_SECRET=change-this-32-char-secret-key

# ── CORS ──
CORS_ORIGIN=http://localhost:3000

# ── Admin ──
# Comma-separated admin emails (optional, dev mode allows all)
ADMIN_EMAILS=admin@example.com

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
