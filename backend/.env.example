# ─── YellowCEX Backend ───────────────────────────────────────
# Copy this file to .env and fill in your values

# ── Environment ──
NODE_ENV=development          # development | production
NETWORK=testnet               # testnet | mainnet
PORT=4000

# ── Supabase ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── JWT ──
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# ── Binance ──
BINANCE_WS_URL=wss://testnet.binance.vision
BINANCE_REST_URL=https://testnet.binance.vision

# ── Ethereum RPC ──
ETH_RPC=https://sepolia.infura.io/v3/your-infura-key

# ── HD Wallet ──
HD_WALLET_MNEMONIC=abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about
ENCRYPTION_SECRET=change-this-32-char-encryption-secret

# ── CORS ──
CORS_ORIGIN=http://localhost:3000

# ── Admin ──
ADMIN_EMAILS=admin@example.com
